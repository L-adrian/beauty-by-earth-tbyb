            } else {
              go(idx + 1, true);
            }
            start();
          }
          touchStartX = null;
          touchStartY = null;
        },
        { passive: true }
      );
      wrap.addEventListener(
        'touchcancel',
        function () {
          touchStartX = null;
          touchStartY = null;
        },
        { passive: true }
      );
      wrap.addEventListener('keydown', function (event) {
        if (event.key === 'ArrowLeft') {
          stop();
          go(idx - 1, true);
          start();
        }
        if (event.key === 'ArrowRight') {
          stop();
          go(idx + 1, true);
          start();
        }
      });
      wrap.addEventListener('mouseenter', stop);
      wrap.addEventListener('mouseleave', start);
      wrap.addEventListener('focusin', stop);
      wrap.addEventListener('focusout', function (event) {
        if (!wrap.contains(event.relatedTarget)) start();
      });
      window.addEventListener('resize', scheduleTrackHeight);
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(scheduleTrackHeight);
      }
      render(false);
      start();
    }

    function initStrip(selector, viewportSelector, prevSelector, nextSelector, step) {
      var module = section.querySelector(selector);
      if (!module) return;
      var viewport = module.querySelector(viewportSelector);
      var prev = module.querySelector(prevSelector);
      var next = module.querySelector(nextSelector);
      var progress = module.querySelector('[data-a-ugc-progress]');
      var progressThumb = progress ? progress.querySelector('.bbe-a__strip-progress-thumb') : null;
      var pagination = module.querySelector('[data-a-strip-pagination]');
      var dots = pagination ? Array.prototype.slice.call(pagination.querySelectorAll('[data-a-strip-dot]')) : [];
      if (!viewport) return;
      function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
      }
      function getMaxScroll() {
        return Math.max(0, viewport.scrollWidth - viewport.clientWidth);
      }
      function update() {
        var max = getMaxScroll();
        if (prev && next) {
          prev.disabled = viewport.scrollLeft <= 1;
          next.disabled = viewport.scrollLeft >= max - 1;
        }
        if (progress && progressThumb) {
          if (max <= 0) {
            progress.style.setProperty('--bbe-a-ugc-progress', '0px');
            return;
          }
          var ratio = clamp(viewport.scrollLeft / max, 0, 1);
          var travel = Math.max(0, progress.clientWidth - progressThumb.offsetWidth);
          progress.style.setProperty('--bbe-a-ugc-progress', travel * ratio + 'px');
        }
        if (dots.length) {
          var activeIndex = 0;
          if (max > 0 && dots.length > 1) {
            activeIndex = Math.round((viewport.scrollLeft / max) * (dots.length - 1));
          }
          activeIndex = Math.max(0, Math.min(dots.length - 1, activeIndex));
