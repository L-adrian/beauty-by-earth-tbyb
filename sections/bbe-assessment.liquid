        if (!btn || !ans) return;
        btn.addEventListener('click', function () {
          var open = btn.getAttribute('aria-expanded') === 'true';
          if (single) closeAll();
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
          ans.hidden = open;
        });
      });
    }

    function initStickyHeader() {
      var header = section.querySelector('.bbe-a__header');
      if (!header) return;
      if (header.getAttribute('data-sticky-enabled') !== 'true') {
        header.classList.remove('is-scrolled');
        return;
      }

      function syncHeaderState() {
        header.classList.toggle('is-scrolled', window.scrollY > 12);
      }

      syncHeaderState();
      window.addEventListener('scroll', syncHeaderState, { passive: true });
    }

    function initIngredients() {
      var ingredients = section.querySelector('.bbe-a__ingredients');
      var toggle = section.querySelector('[data-a-ingredients-toggle]');
      if (!ingredients || !toggle) return;
      var label = toggle.querySelector('[data-a-ingredients-toggle-label]');
      var openLabel = toggle.getAttribute('data-label-open') || 'See full ingredients';
      var closeLabel = toggle.getAttribute('data-label-close') || 'Hide ingredients';

      function setState(open) {
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.classList.toggle('is-open', open);
        ingredients.classList.toggle('is-open', open);
        if (label) label.textContent = open ? closeLabel : openLabel;
      }

      toggle.addEventListener('click', function () {
        var open = toggle.getAttribute('aria-expanded') === 'true';
        setState(!open);
      });

      setState(false);
    }

    function initVideoButtons() {
      var isMobile = window.matchMedia('(hover: none)').matches;
      var activeMobileVideo = null;
      var activeMobilePlayBtn = null;

      section.querySelectorAll('.bbe-a__testi').forEach(function (card) {
        var video = card.querySelector('video');
        var playBtn = card.querySelector('[data-a-play-btn]');
        var muteBtn = card.querySelector('[data-a-mute-btn]');
        if (!video) return;

        video.muted = true;

        if (isMobile) {
          if (muteBtn) muteBtn.hidden = true;
          if (playBtn) playBtn.hidden = false;

          function playMobileVideo() {
            if (activeMobileVideo && activeMobileVideo !== video) {
              activeMobileVideo.pause();
              activeMobileVideo.currentTime = 0;
              activeMobileVideo.muted = true;
              if (activeMobilePlayBtn) activeMobilePlayBtn.hidden = false;
            }

            video.muted = false;
            video.play().catch(function () {
              // Fallback for autoplay restrictions
              video.muted = true;
              video.play();
            });
            if (playBtn) playBtn.hidden = true;
            activeMobileVideo = video;
            activeMobilePlayBtn = playBtn;
          }

          function toggleMobileVideo() {
            if (video.paused) {
              playMobileVideo();
              return;
            }

            // Same video tap: pause only (no reset).
            video.pause();
            if (playBtn) playBtn.hidden = false;
            if (activeMobileVideo === video) {
              activeMobileVideo = null;
              activeMobilePlayBtn = null;
            }
          }

          if (playBtn) {
            playBtn.addEventListener('click', function (e) {
              e.stopPropagation();
              toggleMobileVideo();
            });
          }

          card.addEventListener('click', function () {
            toggleMobileVideo();
          });

          video.addEventListener('ended', function () {
            video.currentTime = 0;
            video.muted = true;
            if (playBtn) playBtn.hidden = false;
            if (activeMobileVideo === video) {
              activeMobileVideo = null;
              activeMobilePlayBtn = null;
            }
          });

          return;
        } else {
          // Desktop: hover plays, leave pauses
          if (playBtn) playBtn.hidden = true;

          card.addEventListener('mouseenter', function () {
            video.play();
            if (muteBtn) muteBtn.hidden = false;
          });

          card.addEventListener('mouseleave', function () {
            video.pause();
            video.currentTime = 0;
            if (muteBtn) muteBtn.hidden = true;
          });

          // Mute/unmute toggle
          if (muteBtn) {
            muteBtn.hidden = true;
            muteBtn.addEventListener('click', function (e) {
              e.stopPropagation();
              video.muted = !video.muted;
              muteBtn.setAttribute('aria-label', video.muted ? 'Unmute' : 'Mute');
              muteBtn.innerHTML = video.muted ? '&#128263;' : '&#128266;';
            });
          }
        }
      });
    }

    var reviews = section.querySelector('[data-a-reviews]');
    initCarousel(
      '[data-a-reviews]',
      '[data-a-reviews-slide]',
      '[data-a-reviews-prev]',
      '[data-a-reviews-next]',
      reviews ? reviews.getAttribute('data-autoplay') === 'true' : false,
      reviews ? parseInt(reviews.getAttribute('data-speed') || '5000', 10) : 5000
    );
    initStrip('[data-a-ugc]', '[data-a-ugc-viewport]', '[data-a-ugc-prev]', '[data-a-ugc-next]', 344);
    initStrip(
      '[data-a-testimonials]',
      '[data-a-testimonials-viewport]',
      '[data-a-testimonials-prev]',
      '[data-a-testimonials-next]',
      300
    );
    initBeforeAfter();
    initFaq();
    initStickyHeader();
    initIngredients();
    initVideoButtons();
  })();
</script>

