{%- assign promo_blocks = section.blocks | where: 'type', 'promo_message' -%}
{%- assign hero_bullets = section.blocks | where: 'type', 'hero_bullet' -%}
{%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
{%- assign ugc_tiles = section.blocks | where: 'type', 'ugc_tile' -%}
{%- assign ingredient_chips = section.blocks | where: 'type', 'ingredient_chip' -%}
{%- assign testimonial_tiles = section.blocks | where: 'type', 'testimonial_tile' -%}
{%- assign faq_items = section.blocks | where: 'type', 'faq_item' -%}
{%- assign hero_headline = section.settings.hero_headline -%}
{%- if hero_headline contains 'Love It. Or' -%}
  {%- assign hero_headline = hero_headline | replace: 'Love It. Or', 'Love It.<br>Or' -%}
{%- endif -%}
<section
  id="bbe-assessment-{{ section.id }}"
  class="bbe-a bbe-a--{{ section.settings.button_style }}"
  data-bbe-assessment
>
  {%- if section.settings.show_promo_bar and promo_blocks.size > 0 -%}
    <div class="bbe-a__promo bbe-a__promo--{{ section.settings.promo_color_scheme }}">
      <div class="bbe-a__shell bbe-a__promo-shell">
        {%- for block in promo_blocks -%}
          <div class="bbe-a__promo-item" {{ block.shopify_attributes }}>
            {%- if block.settings.link_url != blank -%}<a href="{{ block.settings.link_url }}">{%- endif -%}
            {%- if block.settings.label != blank -%}
              <strong class="bbe-a__promo-label">{{ block.settings.label | escape }}</strong>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <span class="bbe-a__promo-text">{{ block.settings.text | escape }}</span>
            {%- endif -%}
            {%- if block.settings.link_url != blank -%}</a>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_header_row -%}
    <header
      class="bbe-a__header{% if section.settings.enable_sticky_header %} is-sticky-enabled{% endif %}"
      data-sticky-enabled="{{ section.settings.enable_sticky_header }}"
    >
      <div class="bbe-a__shell bbe-a__header-shell">
        <div class="bbe-a__header-left">
          <button type="button" class="bbe-a__hamburger" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
          <nav class="bbe-a__nav" aria-label="Main navigation">
            <ul role="list">
              {%- if section.settings.header_nav_link_1_text != blank -%}
                <li>
                  <a href="{{ section.settings.header_nav_link_1_url | default: '#' }}">
                    {{- section.settings.header_nav_link_1_text -}}
                  </a>
                </li>
              {%- endif -%}
              {%- if section.settings.header_nav_link_2_text != blank -%}
                <li>
                  <a href="{{ section.settings.header_nav_link_2_url | default: '#' }}">
                    {{- section.settings.header_nav_link_2_text -}}
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </nav>
        </div>
        <a href="{{ routes.root_url }}" class="bbe-a__logo" aria-label="{{ shop.name }}">
          {%- if section.settings.header_logo != blank -%}
            {%- assign header_logo_alt = section.settings.header_logo.alt | default: shop.name -%}
            {%- assign header_logo_src_width = section.settings.header_logo_width | times: 2 -%}
            <img
              src="{{ section.settings.header_logo | image_url: width: header_logo_src_width }}"
              alt="{{ header_logo_alt | escape }}"
              class="bbe-a__logo-img"
              loading="eager"
              width="{{ section.settings.header_logo.width }}"
              height="{{ section.settings.header_logo.height }}"
            >
          {%- else -%}
            {{ shop.name }}
          {%- endif -%}
        </a>
        <div class="bbe-a__header-right">
          {%- if section.settings.header_cta_text != blank -%}
            <a href="{{ section.settings.header_cta_url | default: '#' }}" class="bbe-a__btn bbe-a__btn--header">
              {{- section.settings.header_cta_text -}}
              &rarr;
            </a>
          {%- endif -%}
        </div>
      </div>
    </header>
  {%- endif -%}

  {%- if section.settings.show_hero -%}
    <div class="bbe-a__hero">
      <div class="bbe-a__shell bbe-a__hero-shell">
        <div class="bbe-a__hero-copy">
          {%- if section.settings.hero_headline != blank -%}
            <h1>{{ hero_headline }}</h1>
          {%- endif -%}
          {%- if section.settings.hero_subheadline != blank -%}
            <p class="bbe-a__hero-sub">{{ section.settings.hero_subheadline }}</p>
          {%- endif -%}
          {%- if hero_bullets.size > 0 -%}
            <ul role="list" class="bbe-a__hero-bullets">
              {%- for block in hero_bullets -%}
                <li {{ block.shopify_attributes }}>
                  <span class="bbe-a__bullet-mark" aria-hidden="true">&#10003;</span>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          <div class="bbe-a__hero-actions">
            {%- if section.settings.hero_primary_cta_text != blank -%}
              <a
                href="{{ section.settings.hero_primary_cta_url | default: '#' }}"
                class="bbe-a__btn bbe-a__btn--primary"
              >
                {{- section.settings.hero_primary_cta_text -}}
              </a>
            {%- endif -%}
            {%- if section.settings.hero_secondary_cta_text != blank -%}
              <a
                href="{{ section.settings.hero_secondary_cta_url | default: '#' }}"
                class="bbe-a__btn bbe-a__btn--secondary"
              >
                {{- section.settings.hero_secondary_cta_text -}}
              </a>
            {%- endif -%}
          </div>
        </div>
        {%- if section.settings.hero_show_badge -%}
          <div
            class="bbe-a__badge-wrap"
            aria-label="{{ section.settings.hero_badge_line }} {{ section.settings.hero_badge_highlight }}"
          >
            <svg
              class="bbe-a__badge-ring"
              viewBox="0 0 140 140"
              overflow="visible"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <defs>
                <path id="bbe-a-badge-path-{{ section.id }}" d="M 70,70 m 0,61 a 61,61 0 0,1 0,-122 a 61,61 0 0,1 0,122" />
              </defs>
              <text>
                <textPath href="#bbe-a-badge-path-{{ section.id }}" startOffset="45%" text-anchor="middle">{{ section.settings.hero_badge_line }}</textPath>
              </text>
            </svg>
            <div class="bbe-a__badge">{{ section.settings.hero_badge_highlight }}</div>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_reviews -%}
    <div
      class="bbe-a__reviews"
      data-a-reviews
      data-autoplay="{{ section.settings.reviews_autoplay }}"
      data-speed="{{ section.settings.reviews_autoplay_seconds | times: 1000 }}"
    >
      {%- if section.settings.reviews_background_image != blank -%}
        {{
          section.settings.reviews_background_image
          | image_url: width: 2200
          | image_tag:
            widths: '800,1200,1600,2000,2200',
            sizes: '100vw',
            loading: 'lazy',
            alt: '',
            class: 'bbe-a__reviews-bg'
        }}
      {%- endif -%}
      <div class="bbe-a__shell">
        <div class="bbe-a__reviews-card" data-a-reviews-carousel aria-live="off" tabindex="0">
          {%- if review_blocks.size > 1 -%}
            <button
              class="bbe-a__nav-btn bbe-a__nav-btn--prev"
              data-a-reviews-prev
              type="button"
              aria-label="Previous review"
            >
              <span class="bbe-a__nav-icon" aria-hidden="true"></span>
            </button>
            <button
              class="bbe-a__nav-btn bbe-a__nav-btn--next"
              data-a-reviews-next
              type="button"
              aria-label="Next review"
            >
              <span class="bbe-a__nav-icon" aria-hidden="true"></span>
            </button>
          {%- endif -%}
          <h2 class="bbe-a__title">
            {{ section.settings.reviews_headline }}
            <em>{{ section.settings.reviews_headline_emphasis }}</em>
          </h2>
          <p class="bbe-a__stars" aria-label="{{ section.settings.reviews_star_rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span
                class="bbe-a__star{% if i <= section.settings.reviews_star_rating %} is-filled{% endif %}"
                aria-hidden="true"
              >
                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                  <path d="M12 1.8l3.1 6.28 6.93 1-5.01 4.88 1.18 6.89L12 17.6l-6.2 3.25 1.18-6.89L1.97 9.08l6.93-1L12 1.8z" />
                </svg>
              </span>
            {%- endfor -%}
          </p>
          {%- if review_blocks.size > 0 -%}
            <div class="bbe-a__reviews-track" data-a-reviews-track>
              {%- for block in review_blocks -%}
                {%- assign verified = block.settings.verified_label
                  | default: section.settings.reviews_verified_label
                -%}
                <article
                  class="bbe-a__review{% if forloop.first %} is-active{% endif %}"
                  data-a-reviews-slide
                  {% if forloop.first %}
                    aria-hidden="false"
                  {% else %}
                    aria-hidden="true"
                  {% endif %}
                  {{ block.shopify_attributes }}
                >
                  <h3>“{{ block.settings.review_title }}”</h3>
                  {%- if block.settings.subtitle != blank -%}
                    <p>{{ block.settings.subtitle }}</p>
                  {%- endif -%}
                  <p>{{ block.settings.body | escape | newline_to_br }}</p>
                  <footer class="bbe-a__review-footer">
                    {%- if block.settings.author != blank -%}
                      <strong class="bbe-a__review-author">• {{ block.settings.author }}</strong>
                    {%- endif -%}
                    {%- if verified != blank -%}
                      <span class="bbe-a__review-verified">{{ verified }}</span>
                    {%- endif -%}
                  </footer>
                </article>
              {%- endfor -%}
            </div>
          {%- endif -%}
          {%- if review_blocks.size > 1 -%}
            <div class="bbe-a__reviews-pagination" data-a-reviews-pagination aria-label="Review navigation">
              {%- for block in review_blocks -%}
                <button
                  type="button"
                  class="bbe-a__reviews-dot{% if forloop.first %} is-active{% endif %}"
                  data-a-reviews-dot
                  data-index="{{ forloop.index0 }}"
                  aria-label="Go to review {{ forloop.index }}"
                  aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
                ></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_ugc_strip and ugc_tiles.size > 0 -%}
    <div class="bbe-a__strip" data-a-ugc>
      <div class="bbe-a__shell">
        {%- if section.settings.ugc_show_arrows_desktop -%}
          <div class="bbe-a__actions">
            <button type="button" data-a-ugc-prev aria-label="Previous tiles">&#8592;</button>
            <button type="button" data-a-ugc-next aria-label="Next tiles">&#8594;</button>
          </div>
        {%- endif -%}
        <div class="bbe-a__viewport" data-a-ugc-viewport>
          <ul class="bbe-a__track" role="list">
            {%- for block in ugc_tiles -%}
              <li class="bbe-a__tile" {{ block.shopify_attributes }}>
                {%- if block.settings.link_url != blank -%}
                  <a href="{{ block.settings.link_url }}" class="bbe-a__media">
                {%- else -%}
                  <div class="bbe-a__media">
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 420, height: 534, crop: 'center'
                    | image_tag:
                      width: 420,
                      height: 534,
                      loading: 'lazy',
                      alt: block.settings.alt_text,
                      class: 'bbe-a__img'
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'bbe-a__img bbe-a__img--placeholder' }}
                {%- endif -%}
                {%- if block.settings.link_url != blank -%}</a>{%- else -%}</div>{%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
        {%- if ugc_tiles.size > 1 -%}
          <div class="bbe-a__strip-progress" data-a-ugc-progress aria-hidden="true">
            <span class="bbe-a__strip-progress-thumb"></span>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_before_after -%}
    {%- assign before_label = section.settings.before_after_before_label | default: 'Before' -%}
    {%- assign after_label = section.settings.before_after_after_label | default: 'After' -%}
    <div class="bbe-a__before-after">
      <div class="bbe-a__shell">
        <h2 class="bbe-a__title">{{ section.settings.before_after_heading }}</h2>
        {%- if section.settings.before_after_subheading != blank -%}
          <p class="bbe-a__sub">{{ section.settings.before_after_subheading }}</p>
        {%- endif -%}
        <p class="bbe-a__sr-only" id="bbe-a-ba-help-{{ section.id }}">
          Drag the slider left or right to compare {{ before_label }} and {{ after_label }} images. You can also use the
          left and right arrow keys while focused on the slider handle.
        </p>
        <div
          class="bbe-a__ba"
          data-a-before-after
          data-before-label="{{ before_label | escape }}"
          data-after-label="{{ after_label | escape }}"
          role="group"
          aria-label="{{ before_label }} and {{ after_label }} image comparison"
        >
          <div class="bbe-a__ba-pane" id="bbe-a-before-pane-{{ section.id }}">
            {%- if section.settings.before_after_before_image != blank -%}
              {{
                section.settings.before_after_before_image
                | image_url: width: 1600
                | image_tag: loading: 'lazy', alt: section.settings.before_after_before_label, class: 'bbe-a__ba-img'
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'bbe-a__ba-img bbe-a__ba-img--placeholder' }}
            {%- endif -%}
          </div>
          <div
            class="bbe-a__ba-pane bbe-a__ba-pane--after"
            data-a-before-after-pane
            id="bbe-a-after-pane-{{ section.id }}"
          >
            {%- if section.settings.before_after_after_image != blank -%}
              {{
                section.settings.before_after_after_image
                | image_url: width: 1600
                | image_tag: loading: 'lazy', alt: section.settings.before_after_after_label, class: 'bbe-a__ba-img'
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'bbe-a__ba-img bbe-a__ba-img--placeholder' }}
            {%- endif -%}
          </div>
          <div
            class="bbe-a__ba-handle"
            data-a-before-after-handle
            role="slider"
            tabindex="0"
            aria-label="{{ before_label }} and {{ after_label }} comparison slider"
            aria-describedby="bbe-a-ba-help-{{ section.id }}"
            aria-controls="bbe-a-before-pane-{{ section.id }} bbe-a-after-pane-{{ section.id }}"
            aria-orientation="horizontal"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="50"
            aria-valuetext="{{ before_label }} 50%, {{ after_label }} 50%"
          >
            <span class="bbe-a__ba-handle-line" aria-hidden="true"></span>
            <span class="bbe-a__ba-knob" aria-hidden="true">
              <span class="bbe-a__ba-knob-grip"></span>
            </span>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_ingredients -%}
    {%- assign ingredients_button_text = section.settings.ingredients_button_text | default: 'See full ingredients' -%}
    {%- assign ingredients_button_close_text = 'Hide ingredients' -%}
    <div class="bbe-a__ingredients">
      <div class="bbe-a__shell bbe-a__ingredients-shell">
        <div class="bbe-a__ingredients-grid">
          {%- for block in ingredient_chips limit: 4 -%}
            {%- assign chip_alt = block.settings.title | default: section.settings.ingredients_heading -%}
            {%- assign slot_class = '' -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                {%- assign slot_class = 'bbe-a__ingredients-slot--top-left' -%}
              {%- when 2 -%}
                {%- assign slot_class = 'bbe-a__ingredients-slot--top-right' -%}
              {%- when 3 -%}
                {%- assign slot_class = 'bbe-a__ingredients-slot--bottom-left' -%}
              {%- when 4 -%}
                {%- assign slot_class = 'bbe-a__ingredients-slot--bottom-right' -%}
            {%- endcase -%}
            <div class="bbe-a__ingredients-slot {{ slot_class }}">
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="bbe-a__ingredient-chip" {{ block.shopify_attributes }}>
              {%- else -%}
                <div class="bbe-a__ingredient-chip" {{ block.shopify_attributes }}>
              {%- endif -%}
              <span class="bbe-a__ingredient-chip-icon">
                {%- if block.settings.icon != blank -%}
                  {{
                    block.settings.icon
                    | image_url: width: 240, height: 240, crop: 'center'
                    | image_tag:
                      width: 120,
                      height: 120,
                      loading: 'lazy',
                      alt: chip_alt,
                      class: 'bbe-a__ingredient-chip-icon-image'
                  }}
                {%- else -%}
                  {{
                    'image'
                    | placeholder_svg_tag: 'bbe-a__ingredient-chip-icon-image bbe-a__ingredient-chip-icon-image--placeholder'
                  }}
                {%- endif -%}
              </span>
              <span class="bbe-a__ingredient-chip-copy">
                <span class="bbe-a__ingredient-chip-title">{{ block.settings.title }}</span>
                {%- if block.settings.body != blank -%}
                  <span class="bbe-a__ingredient-chip-body">{{ block.settings.body }}</span>
                {%- endif -%}
              </span>
              {%- if block.settings.link_url != blank -%}</a>{%- else -%}</div>{%- endif -%}
            </div>
          {%- endfor -%}

          <div class="bbe-a__ingredients-copy bbe-a__ingredients-copy--left">
            {%- if section.settings.ingredients_heading != blank -%}
              <h2 class="bbe-a__ingredients-heading">{{ section.settings.ingredients_heading }}</h2>
            {%- endif -%}
            {%- if section.settings.ingredients_tagline_1 != blank -%}
              <p class="bbe-a__ingredients-tagline bbe-a__ingredients-tagline--left">
                {{ section.settings.ingredients_tagline_1 }}
              </p>
            {%- endif -%}
          </div>

          <div class="bbe-a__ingredients-center">
            <svg
              class="bbe-a__ingredients-ring"
              viewBox="0 0 560 560"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
            >
              <circle cx="280" cy="280" r="279.5" />
            </svg>
            <div class="bbe-a__ingredients-product">
              {%- if section.settings.ingredients_product_image != blank -%}
                {{
                  section.settings.ingredients_product_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '240,320,420,540,720,900,1200',
                    sizes: '(max-width: 989px) min(65vw, 420px), 360px',
                    loading: 'lazy',
                    alt: section.settings.ingredients_heading,
                    class: 'bbe-a__ingredients-image'
                }}
              {%- else -%}
                {{
                  'product-1'
                  | placeholder_svg_tag: 'bbe-a__ingredients-image bbe-a__ingredients-image--placeholder'
                }}
              {%- endif -%}
            </div>
          </div>

          <div class="bbe-a__ingredients-copy bbe-a__ingredients-copy--right">
            {%- if section.settings.ingredients_tagline_2 != blank -%}
              <p class="bbe-a__ingredients-tagline">{{ section.settings.ingredients_tagline_2 }}</p>
            {%- endif -%}
            <button
              type="button"
              class="bbe-a__ingredients-btn"
              data-a-ingredients-toggle
              aria-expanded="false"
              data-label-open="{{ ingredients_button_text | escape }}"
              data-label-close="{{ ingredients_button_close_text }}"
            >
              <span data-a-ingredients-toggle-label>{{- ingredients_button_text -}}</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_testimonials and testimonial_tiles.size > 0 -%}
    <div class="bbe-a__strip" data-a-testimonials>
      <div class="bbe-a__shell">
        <h2 class="bbe-a__title">{{ section.settings.testimonials_heading }}</h2>
        {%- if section.settings.testimonials_show_arrows_desktop -%}
          <div class="bbe-a__actions">
            <button type="button" data-a-testimonials-prev aria-label="Previous testimonials">&#8592;</button>
            <button type="button" data-a-testimonials-next aria-label="Next testimonials">&#8594;</button>
          </div>
        {%- endif -%}
        <div class="bbe-a__viewport" data-a-testimonials-viewport>
          <ul class="bbe-a__track" role="list">
            {%- for block in testimonial_tiles -%}
              <li class="bbe-a__tile" {{ block.shopify_attributes }}>
                <div class="bbe-a__testi">
                  {%- if block.settings.video != blank -%}
                    {{-
                      block.settings.video
                      | video_tag: image_size: '450x', loop: true, muted: true, class: 'bbe-a__testi-video'
                    -}}
                    <button type="button" data-a-play-btn class="bbe-a__play" aria-label="Play video">&#9658;</button>
                    <button type="button" data-a-mute-btn class="bbe-a__mute" aria-label="Unmute">&#128263;</button>
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'bbe-a__testi-img bbe-a__testi-img--placeholder' }}
                  {%- endif -%}
                </div>
                {%- if block.settings.caption != blank -%}
                  <p class="bbe-a__cap">{{ block.settings.caption }}</p>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
        {%- if testimonial_tiles.size > 1 -%}
          <div class="bbe-a__testimonials-pagination" data-a-strip-pagination aria-label="Testimonials navigation">
            {%- for block in testimonial_tiles -%}
              <button
                type="button"
                class="bbe-a__testimonials-dot{% if forloop.first %} is-active{% endif %}"
                data-a-strip-dot
                data-a-strip-dot-index="{{ forloop.index0 }}"
                aria-label="Go to testimonial {{ forloop.index }}"
                aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_faq -%}
    <div class="bbe-a__faq" data-a-faq data-single-open="{{ section.settings.faq_single_open }}">
      <div class="bbe-a__faq-shell">
        <div class="bbe-a__faq-img-wrap">
          {%- if section.settings.faq_image != blank -%}
            {{
              section.settings.faq_image
              | image_url: width: 1400
              | image_tag: loading: 'lazy', alt: section.settings.faq_heading, class: 'bbe-a__faq-img'
            }}
          {%- endif -%}
        </div>
        <div class="bbe-a__faq-copy">
          <h2 class="bbe-a__title">{{ section.settings.faq_heading }}</h2>
          <ul role="list">
            {%- for block in faq_items -%}
              <li class="bbe-a__faq-item" {{ block.shopify_attributes }}>
                <button
                  type="button"
                  data-a-faq-btn
                  aria-expanded="false"
                  aria-controls="faq-{{ section.id }}-{{ forloop.index }}"
                  id="faq-btn-{{ section.id }}-{{ forloop.index }}"
                >
                  {{ block.settings.question }}
                  <span class="bbe-a__faq-chevron" aria-hidden="true"></span>
                </button>
                <div
                  id="faq-{{ section.id }}-{{ forloop.index }}"
                  data-a-faq-answer
                  hidden
                  aria-labelledby="faq-btn-{{ section.id }}-{{ forloop.index }}"
                >
                  {%- if block.settings.answer != blank -%}
                    {{ block.settings.answer }}
                  {%- else -%}
                    <p>{{ 'sections.faq.default_answer' | t }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  {%- endif -%}

