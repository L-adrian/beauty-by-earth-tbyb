    function initCarousel(selector, slideSelector, prevSelector, nextSelector, autoplay, speed) {
      var wrap = section.querySelector(selector);
      if (!wrap) return;
      var slides = Array.prototype.slice.call(wrap.querySelectorAll(slideSelector));
      var prev = wrap.querySelector(prevSelector);
      var next = wrap.querySelector(nextSelector);
      var track = wrap.querySelector('[data-a-reviews-track]');
      var dots = Array.prototype.slice.call(wrap.querySelectorAll('[data-a-reviews-dot]'));
      var idx = 0;
      var timer = null;
      var touchStartX = null;
      var touchStartY = null;
      var swipeThreshold = 42;
      var heightRaf = null;
      if (!slides.length) return;

      function syncTrackHeight() {
        if (!track) return;
        var maxHeight = 0;
        slides.forEach(function (slide) {
          var wasActive = slide.classList.contains('is-active');
          var prevDisplay = slide.style.display;
          var prevPosition = slide.style.position;
          var prevVisibility = slide.style.visibility;
          var prevLeft = slide.style.left;
          var prevRight = slide.style.right;

          if (!wasActive) {
            slide.classList.add('is-active');
            slide.style.display = 'block';
            slide.style.position = 'absolute';
            slide.style.visibility = 'hidden';
            slide.style.left = '0';
            slide.style.right = '0';
          }

          maxHeight = Math.max(maxHeight, slide.offsetHeight);

          if (!wasActive) {
            slide.classList.remove('is-active');
            slide.style.display = prevDisplay;
            slide.style.position = prevPosition;
            slide.style.visibility = prevVisibility;
            slide.style.left = prevLeft;
            slide.style.right = prevRight;
          }
        });

        if (maxHeight > 0) track.style.minHeight = maxHeight + 'px';
      }

      function scheduleTrackHeight() {
        if (!track) return;
        if (heightRaf) cancelAnimationFrame(heightRaf);
        heightRaf = requestAnimationFrame(function () {
          syncTrackHeight();
          heightRaf = null;
        });
      }

      function render(announce) {
        slides.forEach(function (slide, i) {
          var active = i === idx;
          slide.classList.toggle('is-active', active);
