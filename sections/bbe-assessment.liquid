<script>
  (function () {
    var section = document.getElementById('bbe-assessment-{{ section.id }}');
    if (!section) return;

    function initCarousel(selector, slideSelector, prevSelector, nextSelector, autoplay, speed) {
      var wrap = section.querySelector(selector);
      if (!wrap) return;
      var slides = Array.prototype.slice.call(wrap.querySelectorAll(slideSelector));
      var prev = wrap.querySelector(prevSelector);
      var next = wrap.querySelector(nextSelector);
      var idx = 0;
      var timer = null;
      if (!slides.length) return;
      function render(announce) {
        slides.forEach(function (slide, i) {
          var active = i === idx;
          slide.classList.toggle('is-active', active);
          slide.setAttribute('aria-hidden', active ? 'false' : 'true');
        });
        if (wrap.hasAttribute('aria-live')) wrap.setAttribute('aria-live', announce ? 'polite' : 'off');
        if (prev) prev.disabled = slides.length <= 1;
        if (next) next.disabled = slides.length <= 1;
      }
      function go(target, announce) {
        idx = (target + slides.length) % slides.length;
        render(announce);
      }
      function stop() {
        if (timer) {
          clearInterval(timer);
          timer = null;
        }
      }
      function start() {
        if (!autoplay || slides.length <= 1) return;
        stop();
        timer = setInterval(function () {
          go(idx + 1, false);
        }, speed);
      }
      if (prev)
        prev.addEventListener('click', function () {
          stop();
          go(idx - 1, true);
          start();
        });
      if (next)
        next.addEventListener('click', function () {
          stop();
          go(idx + 1, true);
          start();
        });
      wrap.addEventListener('keydown', function (event) {
        if (event.key === 'ArrowLeft') {
          stop();
          go(idx - 1, true);
          start();
        }
        if (event.key === 'ArrowRight') {
          stop();
          go(idx + 1, true);
          start();
        }
      });
      wrap.addEventListener('mouseenter', stop);
      wrap.addEventListener('mouseleave', start);
      wrap.addEventListener('focusin', stop);
      wrap.addEventListener('focusout', function (event) {
        if (!wrap.contains(event.relatedTarget)) start();
      });
      render(false);
      start();
    }

    function initStrip(selector, viewportSelector, prevSelector, nextSelector, step) {
      var module = section.querySelector(selector);
      if (!module) return;
      var viewport = module.querySelector(viewportSelector);
      var prev = module.querySelector(prevSelector);
      var next = module.querySelector(nextSelector);
      if (!viewport) return;
      function update() {
        if (!prev || !next) return;
        var max = viewport.scrollWidth - viewport.clientWidth;
        prev.disabled = viewport.scrollLeft <= 1;
        next.disabled = viewport.scrollLeft >= max - 1;
      }
      if (prev)
        prev.addEventListener('click', function () {
          viewport.scrollBy({ left: step * -1, behavior: 'smooth' });
        });
      if (next)
        next.addEventListener('click', function () {
          viewport.scrollBy({ left: step, behavior: 'smooth' });
        });
      viewport.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    }

    function initBeforeAfter() {
      var slider = section.querySelector('[data-a-before-after]');
      if (!slider) return;
      var handle = slider.querySelector('[data-a-before-after-handle]');
      var after = slider.querySelector('[data-a-before-after-pane]');
      if (!handle || !after) return;
      var beforeLabel = slider.getAttribute('data-before-label') || 'Before';
      var afterLabel = slider.getAttribute('data-after-label') || 'After';
      var dragging = false;
      var activePointerId = null;
      var pos = 50;
      var rafToken = null;
      var pendingPos = 50;
      function clamp(value, min, max) {
        return Math.min(max, Math.max(min, value));
      }
      function setAria(pct) {
        var beforePct = Math.round(pct);
        var afterPct = 100 - beforePct;
        handle.setAttribute('aria-valuenow', beforePct);
        handle.setAttribute('aria-valuetext', beforeLabel + ' ' + beforePct + '%, ' + afterLabel + ' ' + afterPct + '%');
      }
      function setPos(pct) {
        pos = clamp(pct, 0, 100);
        after.style.clipPath = 'inset(0 0 0 ' + pos + '%)';
        handle.style.left = pos + '%';
        setAria(pos);
      }
      function queueSetPos(pct) {
        pendingPos = pct;
        if (rafToken) return;
        rafToken = requestAnimationFrame(function () {
          setPos(pendingPos);
          rafToken = null;
        });
      }
      function fromClientX(clientX) {
        var rect = slider.getBoundingClientRect();
        if (!rect.width) return pos;
        return ((clientX - rect.left) / rect.width) * 100;
      }
      function onPointerMove(event) {
        if (!dragging) return;
        if (activePointerId !== null && event.pointerId !== activePointerId) return;
        queueSetPos(fromClientX(event.clientX));
      }
      function stopDrag(event) {
        if (!dragging) return;
        if (event && activePointerId !== null && event.pointerId !== undefined && event.pointerId !== activePointerId) return;
        if (slider.releasePointerCapture && activePointerId !== null) {
          try {
            slider.releasePointerCapture(activePointerId);
          } catch (error) {}
        }
        dragging = false;
        activePointerId = null;
        slider.classList.remove('is-dragging');
      }
      slider.addEventListener('pointerdown', function (event) {
        if (event.pointerType === 'mouse' && event.button !== 0) return;
        dragging = true;
        activePointerId = event.pointerId;
        slider.classList.add('is-dragging');
        if (slider.setPointerCapture) slider.setPointerCapture(activePointerId);
        queueSetPos(fromClientX(event.clientX));
        event.preventDefault();
      });
      slider.addEventListener('pointermove', onPointerMove, { passive: true });
      slider.addEventListener('pointerup', stopDrag);
      slider.addEventListener('pointercancel', stopDrag);
      slider.addEventListener('lostpointercapture', stopDrag);

      if (!window.PointerEvent) {
        slider.addEventListener('mousedown', function (event) {
          if (event.button !== 0) return;
          dragging = true;
          slider.classList.add('is-dragging');
          queueSetPos(fromClientX(event.clientX));
          event.preventDefault();
        });
        window.addEventListener(
          'mousemove',
          function (event) {
            if (!dragging) return;
            queueSetPos(fromClientX(event.clientX));
          },
          { passive: true }
        );
        window.addEventListener('mouseup', stopDrag);
        slider.addEventListener(
          'touchstart',
          function (event) {
            if (!event.touches || !event.touches.length) return;
            dragging = true;
            slider.classList.add('is-dragging');
            queueSetPos(fromClientX(event.touches[0].clientX));
            event.preventDefault();
          },
          { passive: false }
        );
        slider.addEventListener(
          'touchmove',
          function (event) {
            if (!dragging || !event.touches || !event.touches.length) return;
            queueSetPos(fromClientX(event.touches[0].clientX));
            event.preventDefault();
          },
          { passive: false }
        );
        window.addEventListener('touchend', stopDrag, { passive: true });
        window.addEventListener('touchcancel', stopDrag, { passive: true });
      }
      handle.addEventListener('keydown', function (event) {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          queueSetPos(pos - 2);
        }
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          queueSetPos(pos + 2);
        }
        if (event.key === 'Home') {
          event.preventDefault();
          queueSetPos(0);
        }
        if (event.key === 'End') {
          event.preventDefault();
          queueSetPos(100);
        }
      });
      setPos(50);
    }

    function initFaq() {
      var faq = section.querySelector('[data-a-faq]');
      if (!faq) return;
      var single = faq.getAttribute('data-single-open') === 'true';
      var items = Array.prototype.slice.call(faq.querySelectorAll('.bbe-a__faq-item'));
      if (!items.length) return;
      function closeAll() {
        items.forEach(function (item) {
          var btn = item.querySelector('[data-a-faq-btn]');
          var ans = item.querySelector('[data-a-faq-answer]');
          if (!btn || !ans) return;
          btn.setAttribute('aria-expanded', 'false');
          ans.hidden = true;
        });
      }
      items.forEach(function (item) {
        var btn = item.querySelector('[data-a-faq-btn]');
        var ans = item.querySelector('[data-a-faq-answer]');
        if (!btn || !ans) return;
        btn.addEventListener('click', function () {
          var open = btn.getAttribute('aria-expanded') === 'true';
          if (single) closeAll();
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
          ans.hidden = open;
        });
      });
    }

    function initVideoButtons() {
      var buttons = section.querySelectorAll('[data-a-play-btn]');
      buttons.forEach(function (button) {
        var parent = button.closest('.bbe-a__testi');
        if (!parent) return;
        var video = parent.querySelector('video');
        if (!video) return;
        button.addEventListener('click', function () {
          if (video.paused) {
            video.play();
            button.innerHTML = '&#10074;&#10074;';
            button.setAttribute('aria-label', 'Pause video');
          } else {
            video.pause();
            button.innerHTML = '&#9658;';
            button.setAttribute('aria-label', 'Play video');
          }
        });
      });
    }

    var reviews = section.querySelector('[data-a-reviews]');
    initCarousel(
      '[data-a-reviews]',
      '[data-a-reviews-slide]',
      '[data-a-reviews-prev]',
      '[data-a-reviews-next]',
      reviews ? reviews.getAttribute('data-autoplay') === 'true' : false,
      reviews ? parseInt(reviews.getAttribute('data-speed') || '5000', 10) : 5000
    );
    initStrip('[data-a-ugc]', '[data-a-ugc-viewport]', '[data-a-ugc-prev]', '[data-a-ugc-next]', 344);
    initStrip(
      '[data-a-testimonials]',
      '[data-a-testimonials-viewport]',
      '[data-a-testimonials-prev]',
      '[data-a-testimonials-next]',
      300
    );
    initBeforeAfter();
    initFaq();
    initVideoButtons();
  })();
</script>

