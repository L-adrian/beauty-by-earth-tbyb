{{- 'bbe-before-after.css' | asset_url | stylesheet_tag -}}

<section class="bbe-before-after">
  <div class="bbe-before-after__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="bbe-before-after__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="bbe-before-after__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div
      class="bbe-before-after__slider"
      data-before-after
      role="img"
      aria-label="Before and after comparison: {{ section.settings.before_label }} and {{ section.settings.after_label }}"
    >
      <div class="bbe-before-after__before">
        {%- if section.settings.before_image != blank -%}
          {{
            section.settings.before_image
            | image_url: width: 1000
            | image_tag:
              width: 1000,
              alt: section.settings.before_label,
              loading: 'lazy',
              class: 'bbe-before-after__image'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'bbe-before-after__image bbe-before-after__image--placeholder' }}
        {%- endif -%}
        <span class="bbe-before-after__label" aria-hidden="true">{{ section.settings.before_label }}</span>
      </div>

      <div class="bbe-before-after__after" data-after-pane>
        {%- if section.settings.after_image != blank -%}
          {{
            section.settings.after_image
            | image_url: width: 1000
            | image_tag:
              width: 1000,
              alt: section.settings.after_label,
              loading: 'lazy',
              class: 'bbe-before-after__image'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'bbe-before-after__image bbe-before-after__image--placeholder' }}
        {%- endif -%}
        <span class="bbe-before-after__label bbe-before-after__label--after" aria-hidden="true">{{ section.settings.after_label }}</span>
      </div>

      <div
        class="bbe-before-after__handle"
        data-handle
        role="slider"
        aria-label="Drag to compare before and after"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="50"
        tabindex="0"
      >
        <div class="bbe-before-after__line"></div>
        <div class="bbe-before-after__drag-btn" aria-hidden="true">
          <span>&#8592;</span>
          <span>&#8594;</span>
        </div>
      </div>
    </div>

  </div>
</section>

<script src="{{ 'bbe-before-after.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Before / After slider",
  "tag": "div",
  "class": "bbe-before-after-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the difference"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Before"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before label",
      "default": "Before"
    },
    {
      "type": "header",
      "content": "After"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After label",
      "default": "After"
    }
  ],
  "presets": [
    {
      "name": "Before / After slider"
    }
  ]
}
{% endschema %}
