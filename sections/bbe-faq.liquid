{{- 'bbe-faq.css' | asset_url | stylesheet_tag -}}

<section
  class="bbe-faq"
  data-single-open="{{ section.settings.single_open }}"
>
  <div class="bbe-faq__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="bbe-faq__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="bbe-faq__list" role="list">
        {%- for block in section.blocks -%}
          {%- if block.settings.question != blank -%}
            <li class="bbe-faq__item" {{ block.shopify_attributes }}>
              <button
                class="bbe-faq__question"
                aria-expanded="false"
                aria-controls="faq-answer-{{ section.id }}-{{ forloop.index }}"
                data-faq-btn
              >
                <span>{{ block.settings.question }}</span>
                <span class="bbe-faq__icon" aria-hidden="true"></span>
              </button>

              <div
                id="faq-answer-{{ section.id }}-{{ forloop.index }}"
                class="bbe-faq__answer"
                hidden
                data-faq-answer
              >
                <div class="bbe-faq__answer-inner">
                  {{ block.settings.answer }}
                </div>
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'bbe-faq.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FAQ accordion",
  "tag": "div",
  "class": "bbe-faq-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Still have questions?"
    },
    {
      "type": "checkbox",
      "id": "single_open",
      "label": "Only one open at a time",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Most orders ship within 1–2 business days and arrive within 5–7 business days.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Most orders ship within 1–2 business days and arrive within 5–7 business days.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Is this deodorant safe for sensitive skin?",
            "answer": "<p>Yes! Our formula is dermatologist-tested and free from harsh chemicals, making it suitable for all skin types.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day money-back guarantee. If you are not satisfied, contact us and we will make it right.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
