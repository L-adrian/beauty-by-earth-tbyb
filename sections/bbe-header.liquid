{{- 'bbe-header.css' | asset_url | stylesheet_tag -}}

<header class="bbe-header" role="banner">
  <div class="bbe-header__inner">

    <a href="{{ routes.root_url }}" class="bbe-header__logo-link" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: section.settings.logo_width
          | image_tag:
            width: section.settings.logo_width,
            alt: section.settings.logo.alt | default: shop.name,
            loading: 'eager',
            class: 'bbe-header__logo-img'
        }}
      {%- else -%}
        <span class="bbe-header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="bbe-header__nav" aria-label="Main navigation">
      <ul class="bbe-header__nav-list" role="list">
        {%- if section.settings.nav_link_1_text != blank -%}
          <li>
            <a
              href="{{ section.settings.nav_link_1_url | default: '#' }}"
              class="bbe-header__nav-link"
            >
              {{ section.settings.nav_link_1_text }}
            </a>
          </li>
        {%- endif -%}

        {%- if section.settings.nav_link_2_text != blank -%}
          <li>
            <a
              href="{{ section.settings.nav_link_2_url | default: '#' }}"
              class="bbe-header__nav-link"
            >
              {{ section.settings.nav_link_2_text }}
            </a>
          </li>
        {%- endif -%}
      </ul>
    </nav>

    {%- if section.settings.cta_text != blank -%}
      <a
        href="{{ section.settings.cta_url | default: '#' }}"
        class="bbe-header__cta"
      >
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}

  </div>
</header>

{% schema %}
{
  "name": "Header nav",
  "tag": "div",
  "class": "bbe-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "nav_link_1_text",
      "label": "Link 1 text",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "nav_link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "nav_link_2_text",
      "label": "Link 2 text",
      "default": "About"
    },
    {
      "type": "url",
      "id": "nav_link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Header nav"
    }
  ]
}
{% endschema %}
