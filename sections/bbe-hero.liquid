{{- 'bbe-hero.css' | asset_url | stylesheet_tag -}}

{%- assign media_alt = section.settings.headline | default: shop.name -%}
{%- assign hero_headline = section.settings.headline -%}
{%- if hero_headline contains 'Love It. Or' -%}
  {%- assign hero_headline = hero_headline | replace: 'Love It. Or', 'Love It.<br>Or' -%}
{%- endif -%}

<section class="bbe-hero" aria-label="{{ section.settings.headline | escape }}">
  <div class="bbe-hero__frame">
    <div class="bbe-hero__inner">
      <div class="bbe-hero__content">
        {%- if section.settings.headline != blank -%}
          <h1 class="bbe-hero__headline">{{ hero_headline }}</h1>
        {%- endif -%}

        {%- if section.settings.subheadline != blank -%}
          <p class="bbe-hero__subheadline">{{ section.settings.subheadline }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="bbe-hero__bullets" role="list">
            {%- for block in section.blocks -%}
              {%- if block.settings.text != blank -%}
                <li class="bbe-hero__bullet" {{ block.shopify_attributes }}>
                  <svg
                    class="bbe-hero__bullet-icon"
                    aria-hidden="true"
                    viewBox="0 0 20 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.6"/>
                    <path d="M6.2 10.5L8.7 13L14.2 7.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="bbe-hero__actions">
          {%- if section.settings.primary_cta_text != blank -%}
            <a
              href="{{ section.settings.primary_cta_url | default: '#' }}"
              class="bbe-hero__cta bbe-hero__cta--primary"
            >
              {{ section.settings.primary_cta_text }}
            </a>
          {%- endif -%}

          {%- if section.settings.secondary_cta_text != blank -%}
            <a
              href="{{ section.settings.secondary_cta_url | default: '#' }}"
              class="bbe-hero__cta bbe-hero__cta--secondary"
            >
              {{ section.settings.secondary_cta_text }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="bbe-hero__media">
        {%- if section.settings.show_badge -%}
          {%- if section.settings.badge_image != blank -%}
            {{
              section.settings.badge_image
              | image_url: width: 420
              | image_tag:
                widths: '120,180,240,320,420',
                sizes: '(max-width: 1200px) 120px, 205px',
                loading: 'eager',
                alt: section.settings.badge_line,
                class: 'bbe-hero__badge-image'
            }}
          {%- else -%}
            <svg
              class="bbe-hero__badge"
              viewBox="-18 -18 136 136"
              overflow="visible"
              xmlns="http://www.w3.org/2000/svg"
              aria-label="{{ section.settings.badge_line }} {{ section.settings.badge_highlight }}"
            >
              <circle cx="50" cy="50" r="50" fill="#d9735c"/>
              <text
                x="50"
                y="65"
                text-anchor="middle"
                font-family="'Figtree', system-ui, sans-serif"
                font-size="50"
                font-weight="500"
                fill="#ffffff"
              >
                {{ section.settings.badge_highlight }}
              </text>
              <defs>
                <path
                  id="circlePath-{{ section.id }}"
                  d="
                    M 10, 50
                    a 40,40 0 1,1 80,0
                    40,40 0 1,1 -80,0
                  "
                />
              </defs>
              <text
                font-family="'Figtree', system-ui, sans-serif"
                font-size="16"
                font-weight="500"
                fill="#000000"
                letter-spacing="-2.1"
                dy="-20"
                transform="rotate(-65 50 50)"
              >
                <textPath href="#circlePath-{{ section.id }}" startOffset="38%" text-anchor="middle">{{ section.settings.badge_line }}</textPath>
              </text>
            </svg>
          {%- endif -%}
        {%- endif -%}

        <div class="bbe-hero__media-stage">
          {%- if section.settings.media_background_image != blank -%}
            {{
              section.settings.media_background_image
              | image_url: width: 2400
              | image_tag:
                widths: '640,960,1200,1600,2000,2400',
                sizes: '(max-width: 1100px) 100vw, 50vw',
                loading: 'eager',
                alt: media_alt,
                class: 'bbe-hero__media-image'
            }}
          {%- else -%}
            <div class="bbe-hero__mock" aria-hidden="true">
              <div class="bbe-hero__mock-bottle bbe-hero__mock-bottle--left"></div>
              <div class="bbe-hero__mock-bottle bbe-hero__mock-bottle--right"></div>
              <div class="bbe-hero__mock-shadow"></div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero offer",
  "tag": "div",
  "class": "bbe-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Try It. Love It. Or Pay Nothing."
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Only pay $40 after 7 days (if you decide to keep it)."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "primary_cta_text",
      "label": "Primary CTA text",
      "default": "START MY FREE TRIAL"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "SEE HOW IT WORKS"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary CTA URL"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "media_background_image",
      "label": "Right media image (PNG)"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show badge",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge image (optional)"
    },
    {
      "type": "text",
      "id": "badge_line",
      "label": "Badge curved text",
      "default": "Get our 2-pack today for $0."
    },
    {
      "type": "text",
      "id": "badge_highlight",
      "label": "Badge center text",
      "default": "$0"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Ships today"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero offer",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Ships today" } },
        { "type": "bullet", "settings": { "text": "Cancel before day 7, no charge" } },
        { "type": "bullet", "settings": { "text": "Autoships every 30 days. Cancel anytime" } }
      ]
    }
  ]
}
{% endschema %}
