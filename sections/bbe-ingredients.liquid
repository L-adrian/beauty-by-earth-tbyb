{{- 'bbe-ingredients.css' | asset_url | stylesheet_tag -}}

<section class="bbe-ingredients">
  <div class="bbe-ingredients__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="bbe-ingredients__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="bbe-ingredients__layout">

      {%- assign leftBlocks  = section.blocks | slice: 0, 2 -%}
      {%- assign rightBlocks = section.blocks | slice: 2, 2 -%}

      <div class="bbe-ingredients__chips bbe-ingredients__chips--left">
        {%- for block in leftBlocks -%}
          <div class="bbe-ingredients__chip" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="bbe-ingredients__chip-icon">
                {{
                  block.settings.icon
                  | image_url: width: 60
                  | image_tag:
                    width: 60,
                    height: 60,
                    alt: block.settings.title,
                    loading: 'lazy'
                }}
              </div>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="bbe-ingredients__chip-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="bbe-ingredients__chip-body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}" class="bbe-ingredients__chip-link">
                Learn more
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <div class="bbe-ingredients__product">
        {%- if section.settings.product_image != blank -%}
          {{
            section.settings.product_image
            | image_url: width: 500
            | image_tag:
              width: 500,
              alt: section.settings.product_image.alt | default: section.settings.heading,
              loading: 'lazy',
              class: 'bbe-ingredients__product-image'
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'bbe-ingredients__product-image bbe-ingredients__product-image--placeholder' }}
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <a
            href="{{ section.settings.button_url | default: '#' }}"
            class="bbe-ingredients__btn"
          >
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
      </div>

      <div class="bbe-ingredients__chips bbe-ingredients__chips--right">
        {%- for block in rightBlocks -%}
          <div class="bbe-ingredients__chip" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="bbe-ingredients__chip-icon">
                {{
                  block.settings.icon
                  | image_url: width: 60
                  | image_tag:
                    width: 60,
                    height: 60,
                    alt: block.settings.title,
                    loading: 'lazy'
                }}
              </div>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="bbe-ingredients__chip-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="bbe-ingredients__chip-body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.link_url != blank -%}
              <a href="{{ block.settings.link_url }}" class="bbe-ingredients__chip-link">
                Learn more
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Clean ingredients",
  "tag": "div",
  "class": "bbe-ingredients-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clean Ingredients"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "See full ingredients"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ingredient name",
          "default": "Ingredient"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Description",
          "default": "A powerful natural ingredient that works with your body."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clean ingredients",
      "blocks": [
        { "type": "ingredient", "settings": { "title": "Orange Peel Oil", "body": "Natural fragrance and skin-brightening properties." } },
        { "type": "ingredient", "settings": { "title": "White Tea Extract", "body": "Rich in antioxidants to protect and nourish." } },
        { "type": "ingredient", "settings": { "title": "Magnesium Hydroxide", "body": "Neutralizes odor without blocking your pores." } },
        { "type": "ingredient", "settings": { "title": "Shea Butter", "body": "Deeply moisturizing for soft, smooth skin." } }
      ]
    }
  ]
}
{% endschema %}
