{{- 'bbe-promo-bar.css' | asset_url | stylesheet_tag -}}

{%- if section.settings.show_bar and section.blocks.size > 0 -%}
  <div
    id="bbe-promo-bar-{{ section.id }}"
    class="bbe-promo-bar{% if section.settings.color_scheme == 'light' %} bbe-promo-bar--light{% endif %}"
    role="region"
    aria-label="Promotional announcement"
  >
    <div class="bbe-promo-bar__inner">
      {%- for block in section.blocks -%}
        {%- assign has_link = false -%}
        {%- if block.settings.link_url != blank -%}
          {%- assign has_link = true -%}
        {%- endif -%}

        <div
          class="bbe-promo-bar__message"
          {{ block.shopify_attributes }}
        >
          {%- if has_link -%}
            <a href="{{ block.settings.link_url }}" class="bbe-promo-bar__link">
              {%- if block.settings.label != blank -%}
                <span class="bbe-promo-bar__message-label">{{ block.settings.label | escape }}</span>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <span class="bbe-promo-bar__message-text">{{ block.settings.text | escape }}</span>
              {%- endif -%}
            </a>
          {%- else -%}
            {%- if block.settings.label != blank -%}
              <span class="bbe-promo-bar__message-label">{{ block.settings.label | escape }}</span>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <span class="bbe-promo-bar__message-text">{{ block.settings.text | escape }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Promo bar",
  "tag": "div",
  "class": "bbe-promo-bar-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show bar",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Bold label",
          "info": "Displayed in bold before the message text",
          "placeholder": "Limited-Time Offer:"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Message text",
          "placeholder": "Try Today for $0"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo bar",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "label": "Limited-Time Offer:",
            "text": "Try Today for $0"
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "7-Day Trial. Only Pay If You Love It."
          }
        }
      ]
    }
  ]
}
{% endschema %}
