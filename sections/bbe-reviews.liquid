{{- 'bbe-reviews.css' | asset_url | stylesheet_tag -}}

{%- assign section_max_width = section.settings.section_max_width | default: 1900 -%}
{%- assign section_min_height_desktop = section.settings.section_min_height_desktop | default: 820 -%}
{%- assign section_min_height_mobile = section.settings.section_min_height_mobile | default: 620 -%}
{%- assign content_padding_y = section.settings.content_padding_y | default: 72 -%}
{%- assign content_padding_x = section.settings.content_padding_x | default: 24 -%}
{%- assign background_color = section.settings.background_color | default: '#ddd2bf' -%}
{%- assign background_overlay_opacity = section.settings.background_overlay_opacity | default: 0 | times: 0.01 -%}
{%- assign card_max_width = section.settings.card_max_width | default: 1680 -%}
{%- assign card_height_desktop = section.settings.card_height_desktop | default: 650 -%}
{%- assign card_height_mobile = section.settings.card_height_mobile | default: 460 -%}
{%- assign card_height_preset = section.settings.card_height_preset | default: 'custom' -%}
{%- assign card_preset_class = '' -%}
{%- case card_height_preset -%}
  {%- when 'h650' -%}
    {%- assign card_preset_class = ' bbe-reviews--h650' -%}
  {%- when 'h700' -%}
    {%- assign card_preset_class = ' bbe-reviews--h700' -%}
  {%- when 'h760' -%}
    {%- assign card_preset_class = ' bbe-reviews--h760' -%}
{%- endcase -%}
{%- assign card_blur = section.settings.card_blur | default: 8 -%}
{%- assign card_opacity = section.settings.card_opacity | default: 86 | times: 0.01 -%}
{%- assign card_radius = section.settings.card_radius | default: 30 -%}
{%- assign card_padding_y = section.settings.card_padding_y | default: 52 -%}
{%- assign card_padding_x = section.settings.card_padding_x | default: 64 -%}
{%- assign card_text_color = section.settings.card_text_color | default: '#111111' -%}
{%- assign autoplay_speed_ms = section.settings.review_autoplay_seconds | default: 5 | times: 1000 -%}

<section
  class="bbe-reviews{{ card_preset_class }}"
  data-bbe-reviews
  data-autoplay="{{ section.settings.review_autoplay }}"
  data-autoplay-speed="{{ autoplay_speed_ms }}"
  style="
    --bbe-reviews-max-width: {{ card_max_width }}px;
    --bbe-reviews-min-height-desktop: {{ section_min_height_desktop }}px;
    --bbe-reviews-min-height-mobile: {{ section_min_height_mobile }}px;
    --bbe-reviews-padding-y: {{ content_padding_y }}px;
    --bbe-reviews-padding-x: {{ content_padding_x }}px;
    --bbe-reviews-bg: {{ background_color }};
    --bbe-reviews-card-text: {{ card_text_color }};
    --bbe-reviews-overlay-opacity: {{ background_overlay_opacity }};
    --bbe-reviews-card-max-width: {{ card_max_width }}px;
    --bbe-reviews-card-height-desktop: {{ card_height_desktop }}px;
    --bbe-reviews-card-height-mobile: {{ card_height_mobile }}px;
    --bbe-reviews-card-blur: {{ card_blur }}px;
    --bbe-reviews-card-opacity: {{ card_opacity }};
    --bbe-reviews-card-radius: {{ card_radius }}px;
    --bbe-reviews-card-padding-y: {{ card_padding_y }}px;
    --bbe-reviews-card-padding-x: {{ card_padding_x }}px;
  "
>
  {%- if section.settings.background_image != blank -%}
    <div class="bbe-reviews__bg" aria-hidden="true">
      {{
        section.settings.background_image
        | image_url: width: 2200
        | image_tag:
          widths: '800,1200,1600,2000,2200',
          sizes: '100vw',
          alt: '',
          loading: 'lazy',
          class: 'bbe-reviews__bg-image'
      }}
    </div>
  {%- endif -%}

  <div class="bbe-reviews__overlay" aria-hidden="true"></div>

  <div class="bbe-reviews__inner">
    <div
      class="bbe-reviews__panel"
      role="region"
      aria-label="Customer reviews"
      aria-live="off"
      data-reviews-carousel
    >
      <button
        class="bbe-reviews__nav bbe-reviews__nav--prev"
        type="button"
        data-reviews-prev
        aria-label="Previous review"
      >
        &#10094;
      </button>

      <button
        class="bbe-reviews__nav bbe-reviews__nav--next"
        type="button"
        data-reviews-next
        aria-label="Next review"
      >
        &#10095;
      </button>

      <div class="bbe-reviews__panel-content">
        {%- if section.settings.headline != blank or section.settings.headline_emphasis != blank -%}
          <h2 class="bbe-reviews__headline">
            {%- if section.settings.headline != blank -%}
              <span>{{ section.settings.headline | escape }}</span>
            {%- endif -%}
            {%- if section.settings.headline_emphasis != blank -%}
              <em>{{ section.settings.headline_emphasis | escape }}</em>
            {%- endif -%}
          </h2>
        {%- endif -%}

        <div class="bbe-reviews__stars" aria-label="{{ section.settings.star_rating }} out of 5 stars">
          {%- for i in (1..5) -%}
            <span
              class="bbe-reviews__star{% if i <= section.settings.star_rating %} bbe-reviews__star--filled{% endif %}"
              aria-hidden="true"
              >&#9733;</span
            >
          {%- endfor -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="bbe-reviews__slides" data-reviews-track>
            {%- for block in section.blocks -%}
              {%- assign review_title = block.settings.review_title -%}
              {%- assign review_subtitle = block.settings.subtitle -%}
              {%- assign review_body = block.settings.body | default: block.settings.quote -%}
              {%- assign review_verified_text = block.settings.verified_label
                | default: section.settings.verified_label
              -%}
              <article
                class="bbe-reviews__slide{% if forloop.first %} is-active{% endif %}"
                data-review-slide
                {% if forloop.first %}
                  aria-hidden="false"
                {% else %}
                  aria-hidden="true"
                {% endif %}
                {{ block.shopify_attributes }}
              >
                {%- if review_title != blank -%}
                  <h3 class="bbe-reviews__review-title">&ldquo;{{ review_title | escape }}&rdquo;</h3>
                {%- endif -%}

                {%- if review_subtitle != blank -%}
                  <p class="bbe-reviews__review-subtitle">{{ review_subtitle | escape }}</p>
                {%- endif -%}

                {%- if review_body != blank -%}
                  <p class="bbe-reviews__review-body">{{ review_body | escape | newline_to_br }}</p>
                {%- endif -%}

                <footer class="bbe-reviews__footer">
                  {%- if block.settings.author != blank -%}
                    <span class="bbe-reviews__author-wrap">
                      <span class="bbe-reviews__author-dot" aria-hidden="true">&#8226;</span>
                      <span class="bbe-reviews__author">{{ block.settings.author | escape }}</span>
                    </span>
                  {%- endif -%}
                  {%- if review_verified_text != blank -%}
                    <span class="bbe-reviews__verified">{{ review_verified_text | escape }}</span>
                  {%- endif -%}
                </footer>
              </article>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script src="{{ 'bbe-reviews.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Reviews panel",
  "tag": "div",
  "class": "bbe-reviews-section",
  "settings": [
    {
      "type": "header",
      "content": "Section size"
