      "step": 20,
      "unit": "px",
      "default": 1900
    },
    {
      "type": "range",
      "id": "section_min_height_desktop",
      "label": "Min height desktop",
      "min": 480,
      "max": 1100,
      "step": 10,
      "unit": "px",
      "default": 820
    },
    {
      "type": "range",
      "id": "section_min_height_mobile",
      "label": "Min height mobile",
      "min": 420,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "content_padding_y",
      "label": "Vertical padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "content_padding_x",
      "label": "Horizontal padding",
      "min": 8,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fallback background color",
      "default": "#ddd2bf"
    },
    {
      "type": "range",
      "id": "background_overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 70,
      "step": 1,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "label": "Card max width",
      "min": 900,
      "max": 1900,
      "step": 10,
      "unit": "px",
      "default": 1680
    },
    {
