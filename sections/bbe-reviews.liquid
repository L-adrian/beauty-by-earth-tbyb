        { "value": "h760", "label": "760 px (QA)" }
      ],
      "default": "custom"
    },
    {
      "type": "range",
      "id": "card_height_desktop",
      "label": "Card height desktop",
      "min": 420,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 650
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "label": "Card height mobile",
      "min": 320,
      "max": 760,
      "step": 10,
      "unit": "px",
      "default": 460
    },
    {
      "type": "range",
      "id": "card_blur",
      "label": "Card blur",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "card_opacity",
      "label": "Card opacity",
      "min": 40,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 86
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 8,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "card_padding_y",
      "label": "Card vertical padding",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "card_padding_x",
      "label": "Card horizontal padding",
      "min": 12,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Over 100K reviews"
    },
    {
      "type": "text",
      "id": "headline_emphasis",
      "label": "Headline emphasis",
      "default": " (and counting)."
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Star rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "verified_label",
      "label": "Verified label",
      "default": "VERIFIED PURCHASE"
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "review_autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "review_autoplay_seconds",
      "label": "Autoplay every",
      "min": 3,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "review_title",
          "label": "Review title",
          "default": "This deodorant is absolute gold!"
        },
        {
          "type": "text",
          "id": "quote",
          "label": "Legacy review body (optional)"
        },
        {
          "type": "text",
          "id": "subtitle",
