{{- 'bbe-testimonials.css' | asset_url | stylesheet_tag -}}

<section class="bbe-testimonials">
  <div class="bbe-testimonials__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="bbe-testimonials__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="bbe-testimonials__carousel"
        role="region"
        aria-label="Customer testimonials"
      >
        <div class="bbe-testimonials__track" data-testimonials-track>
          {%- for block in section.blocks -%}
            <div class="bbe-testimonials__tile" {{ block.shopify_attributes }}>

              {%- if block.settings.video_url != blank -%}
                <div class="bbe-testimonials__media bbe-testimonials__media--video">
                  <video
                    src="{{ block.settings.video_url }}"
                    class="bbe-testimonials__video"
                    playsinline
                    muted
                    loop
                    preload="none"
                    aria-label="{{ block.settings.caption | default: 'Customer video' }}"
                  ></video>
                  <button class="bbe-testimonials__play-btn" aria-label="Play video" data-play-btn>
                    &#9654;
                  </button>
                </div>

              {%- elsif block.settings.image != blank -%}
                <div class="bbe-testimonials__media">
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      width: 400,
                      height: 500,
                      alt: block.settings.caption | default: '',
                      loading: 'lazy',
                      class: 'bbe-testimonials__image'
                  }}
                </div>

              {%- else -%}
                <div class="bbe-testimonials__media">
                  {{ 'image' | placeholder_svg_tag: 'bbe-testimonials__image bbe-testimonials__image--placeholder' }}
                </div>
              {%- endif -%}

              {%- if block.settings.caption != blank -%}
                <p class="bbe-testimonials__caption">{{ block.settings.caption }}</p>
              {%- endif -%}

            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'bbe-testimonials.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "What they are saying",
  "tag": "div",
  "class": "bbe-testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What They Are Saying"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (MP4)",
          "info": "Overrides image if both are set"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What they are saying",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
