{{- 'bbe-ugc-gallery.css' | asset_url | stylesheet_tag -}}

{%- assign section_max_width = section.settings.section_max_width | default: 1900 -%}
{%- assign content_padding_y = section.settings.content_padding_y | default: 24 -%}
{%- assign content_padding_x = section.settings.content_padding_x | default: 18 -%}
{%- assign background_color = section.settings.background_color | default: '#e9e9e9' -%}
{%- assign grid_gap = section.settings.grid_gap | default: 14 -%}
{%- assign columns_desktop = section.settings.columns_desktop | default: 5 -%}
{%- assign columns_mobile = section.settings.columns_mobile | default: '2' -%}
{%- assign card_radius = section.settings.card_radius | default: 22 -%}
{%- assign card_background_color = section.settings.card_background_color | default: '#dcd6ca' -%}
{%- assign image_fit_default = section.settings.image_fit_default | default: 'cover' -%}
{%- assign image_position_default = section.settings.image_position_default | default: 'center center' -%}

<section
  class="bbe-ugc-gallery"
  style="
    --bbe-ugc-max-width: {{ section_max_width }}px;
    --bbe-ugc-padding-y: {{ content_padding_y }}px;
    --bbe-ugc-padding-x: {{ content_padding_x }}px;
    --bbe-ugc-bg: {{ background_color }};
    --bbe-ugc-gap: {{ grid_gap }}px;
    --bbe-ugc-columns-desktop: {{ columns_desktop }};
    --bbe-ugc-columns-mobile: {{ columns_mobile }};
    --bbe-ugc-card-radius: {{ card_radius }}px;
    --bbe-ugc-card-bg: {{ card_background_color }};
    --bbe-ugc-image-fit-default: {{ image_fit_default }};
    --bbe-ugc-image-position-default: {{ image_position_default }};
  "
>
  <div class="bbe-ugc-gallery__inner">
    {%- if section.blocks.size > 0 -%}
      <ul class="bbe-ugc-gallery__grid" role="list">
        {%- for block in section.blocks -%}
          {%- assign block_fit = block.settings.image_fit | default: 'default' -%}
          {%- if block_fit == 'default' -%}
            {%- assign block_fit = image_fit_default -%}
          {%- endif -%}

          {%- assign block_position = block.settings.image_position | default: 'default' -%}
          {%- if block_position == 'default' -%}
            {%- assign block_position = image_position_default -%}
          {%- endif -%}

          <li
            class="bbe-ugc-gallery__item"
            style="
              --bbe-ugc-image-fit: {{ block_fit }};
              --bbe-ugc-image-position: {{ block_position }};
            "
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.link_url != blank -%}
              <a
                href="{{ block.settings.link_url }}"
                class="bbe-ugc-gallery__media"
                aria-label="{{ block.settings.alt_text | default: 'View image' | escape }}"
              >
            {%- else -%}
              <div class="bbe-ugc-gallery__media">
            {%- endif -%}

            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 330, height: 420, crop: 'center'
                | image_tag:
                  alt: block.settings.alt_text | default: '',
                  loading: 'lazy',
                  width: 330,
                  height: 420,
                  class: 'bbe-ugc-gallery__image'
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'bbe-ugc-gallery__image bbe-ugc-gallery__image--placeholder' }}
            {%- endif -%}

            {%- if block.settings.link_url != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "UGC gallery",
  "tag": "div",
  "class": "bbe-ugc-gallery-section",
  "settings": [
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Section max width",
      "min": 1200,
      "max": 2200,
      "step": 20,
      "unit": "px",
      "default": 1900
    },
    {
      "type": "range",
      "id": "content_padding_y",
      "label": "Vertical padding",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "content_padding_x",
      "label": "Horizontal padding",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#e9e9e9"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Image gap",
      "min": 4,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card fallback background",
      "default": "#dcd6ca"
    },
    {
      "type": "header",
      "content": "Default image behavior"
    },
    {
      "type": "select",
      "id": "image_fit_default",
      "label": "Default image fit",
      "options": [
        { "value": "cover", "label": "Cover (crop)" },
        { "value": "contain", "label": "Contain (show full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_position_default",
      "label": "Default image position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    }
  ],
  "blocks": [
    {
      "type": "thumbnail",
      "name": "Thumbnail",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (optional)"
        },
        {
          "type": "header",
          "content": "Image override"
        },
        {
          "type": "select",
          "id": "image_fit",
          "label": "Image fit override",
          "options": [
            { "value": "default", "label": "Use section default" },
            { "value": "cover", "label": "Cover (crop)" },
            { "value": "contain", "label": "Contain (show full image)" }
          ],
          "default": "default"
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image position override",
          "options": [
            { "value": "default", "label": "Use section default" },
            { "value": "center center", "label": "Center" },
            { "value": "center top", "label": "Top" },
            { "value": "center bottom", "label": "Bottom" },
            { "value": "left center", "label": "Left" },
            { "value": "right center", "label": "Right" }
          ],
          "default": "default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC gallery",
      "blocks": [
        { "type": "thumbnail" },
        { "type": "thumbnail" },
        { "type": "thumbnail" },
        { "type": "thumbnail" },
        { "type": "thumbnail" }
      ]
    }
  ]
}
{% endschema %}
