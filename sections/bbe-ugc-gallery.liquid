{{- 'bbe-ugc-gallery.css' | asset_url | stylesheet_tag -}}

<section
  class="bbe-ugc-gallery"
  data-show-arrows="{{ section.settings.show_arrows }}"
>
  <div class="bbe-ugc-gallery__inner">

    {%- if section.blocks.size > 0 -%}
      {%- if section.settings.show_arrows -%}
        <button
          class="bbe-ugc-gallery__arrow bbe-ugc-gallery__arrow--prev"
          aria-label="Scroll left"
          data-ugc-prev
        >
          &#8592;
        </button>
      {%- endif -%}

      <div class="bbe-ugc-gallery__viewport" data-ugc-viewport>
        <ul class="bbe-ugc-gallery__track" role="list" data-ugc-track>
          {%- for block in section.blocks -%}
            <li class="bbe-ugc-gallery__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link_url != blank -%}
                <a
                  href="{{ block.settings.link_url }}"
                  class="bbe-ugc-gallery__link"
                  aria-label="{{ block.settings.alt_text | default: 'View post' }}"
                >
              {%- endif -%}

              <div class="bbe-ugc-gallery__image-wrap">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      width: 400,
                      height: 400,
                      alt: block.settings.alt_text | default: '',
                      loading: 'lazy',
                      class: 'bbe-ugc-gallery__image'
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'bbe-ugc-gallery__image bbe-ugc-gallery__image--placeholder' }}
                {%- endif -%}
              </div>

              {%- if block.settings.link_url != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>

      {%- if section.settings.show_arrows -%}
        <button
          class="bbe-ugc-gallery__arrow bbe-ugc-gallery__arrow--next"
          aria-label="Scroll right"
          data-ugc-next
        >
          &#8594;
        </button>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

<script src="{{ 'bbe-ugc-gallery.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "UGC gallery",
  "tag": "div",
  "class": "bbe-ugc-gallery-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show navigation arrows",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "thumbnail",
      "name": "Thumbnail",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC gallery",
      "blocks": [
        { "type": "thumbnail" },
        { "type": "thumbnail" },
        { "type": "thumbnail" },
        { "type": "thumbnail" },
        { "type": "thumbnail" }
      ]
    }
  ]
}
{% endschema %}
